  date              DateTime
  focus_area        String
  issues            String
  actions_agreed    String
  evidence_urls     String[] // mandatory photo(s) URL(s)
  follow_up_date    DateTime?

  // Measurable results are stored exactly as template checkbox + numeric fields.
  measurable_results Json
  revenue_current    Decimal? @db.Decimal(15, 2)
  employment_new     Int?

  client_created_at DateTime?
  client_updated_at DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  evidence Evidence[]
  phone_follow_ups PhoneFollowUp[]
  qc_checks QcCheck[]

  @@index([enterprise_id, date])
  @@map("coaching_visits")
